<Window x:Class="AxiomFusion.CncController.Dialogs.LogoSpinSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rotação do logo 3D"
        Width="380" SizeToContent="Height"
        MinHeight="200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#1e1e2e" Foreground="#cdd6f4">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" Width="88" IsDefault="True" Margin="6,0,0,0"
                    Style="{StaticResource PrimaryButton}" Click="BtnOk_Click"/>
            <Button Content="Cancelar" Width="88" IsCancel="True" Margin="6,0,0,0"
                    Style="{StaticResource SmallButton}"/>
        </StackPanel>

        <StackPanel>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                       Foreground="#bac2de"
                       Text="Ajuste a velocidade de rotação do símbolo no canto (eixo Z). Zero para parar."/>
            <Label Content="Velocidade (° por segundo, aprox.):" Style="{StaticResource SmallLabel}" Margin="0,0,0,4"/>
            <Slider x:Name="SliderSpeed"
                    Style="{StaticResource DarkSlider}"
                    Minimum="0" Maximum="120" TickFrequency="10"
                    IsSnapToTickEnabled="False"
                    ValueChanged="SliderSpeed_ValueChanged"/>
            <TextBlock x:Name="TbValue" Margin="0,8,0,0"
                       FontSize="18" FontWeight="SemiBold" Foreground="#89b4fa"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </DockPanel>
</Window>
