<Window x:Class="AxiomFusion.CncController.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração da Máquina"
        Width="540" Height="760"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e2e" Foreground="#cdd6f4">

    <DockPanel Margin="8">
        <!-- Botões OK/Cancel -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK"      Width="80" IsDefault="True" Margin="4,0"
                    Style="{StaticResource PrimaryButton}" Click="BtnOk_Click"/>
            <Button Content="Cancelar" Width="80" IsCancel="True" Margin="4,0"
                    Style="{StaticResource SmallButton}"/>
        </StackPanel>

        <TabControl Style="{StaticResource DarkTabControl}">

            <!-- ── Tab 0: Tipo de Máquina ────────────────────────────── -->
            <TabItem Header="Tipo de Máquina">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">

                        <GroupBox Header="Seleccionar Modo de Operação" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <StackPanel Margin="4">
                                <RadioButton x:Name="RbLaser"     Content="Laser — corte / gravação 2D"
                                             Foreground="#cdd6f4" Margin="4,4"
                                             GroupName="MachineType" IsChecked="True"/>
                                <RadioButton x:Name="RbPlasma"    Content="Plasma — corte a tocha 2D (GRBL M3/M5)"
                                             Foreground="#cdd6f4" Margin="4,4"
                                             GroupName="MachineType"/>
                                <RadioButton x:Name="RbDrill"     Content="Fresa / Furadeira CNC"
                                             Foreground="#cdd6f4" Margin="4,4"
                                             GroupName="MachineType"/>
                                <RadioButton x:Name="RbTurn"      Content="Torno CNC"
                                             Foreground="#cdd6f4" Margin="4,4"
                                             GroupName="MachineType"/>
                                <RadioButton x:Name="RbTurnLaser" Content="Torno + Laser combinado"
                                             Foreground="#cdd6f4" Margin="4,4"
                                             GroupName="MachineType"/>
                                <RadioButton x:Name="RbTurnPlasma" Content="Torno + Plasma"
                                             Foreground="#cdd6f4" Margin="4,4"
                                             GroupName="MachineType"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="M Codes — Spindle (Fresa / Torno)" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Content="Spindle ON fwd (M3):"  Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbSpindleOnFwd"  Style="{StaticResource DarkTextBox}" Margin="2"/>

                                <Label Grid.Row="1" Content="Spindle ON rev (M4):"  Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbSpindleOnRev"  Style="{StaticResource DarkTextBox}" Margin="2"/>

                                <Label Grid.Row="2" Content="Spindle OFF (M5):"     Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TbSpindleOff"    Style="{StaticResource DarkTextBox}" Margin="2"/>

                                <Label Grid.Row="3" Content="RPM máximo:"            Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TbSpindleMaxRpm" Style="{StaticResource DarkTextBox}" Margin="2"/>

                                <Label Grid.Row="4" Content="Refrigeração ON (M8):" Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" x:Name="TbCoolantOn"     Style="{StaticResource DarkTextBox}" Margin="2"/>

                                <Label Grid.Row="5" Content="Refrigeração OFF (M9):" Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="5" Grid.Column="1" x:Name="TbCoolantOff"    Style="{StaticResource DarkTextBox}" Margin="2"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="M Codes — Laser em modo TurnLaser" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Content="Laser ON (M7):"   Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbTurnLaserOn"  Style="{StaticResource DarkTextBox}" Margin="2"/>
                                <Label Grid.Row="1" Content="Laser OFF (M107):" Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbTurnLaserOff" Style="{StaticResource DarkTextBox}" Margin="2"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="M Codes — Plasma em modo Torno + Plasma" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Content="Tocha ON (ex. M7):"   Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbTurnPlasmaOn"  Style="{StaticResource DarkTextBox}" Margin="2"/>
                                <Label Grid.Row="1" Content="Tocha OFF (ex. M107):" Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbTurnPlasmaOff" Style="{StaticResource DarkTextBox}" Margin="2"/>
                            </Grid>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Tab 1: Controlador ────────────────────────────────── -->
            <TabItem Header="Controlador / M Codes">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">

                        <!-- Tipo -->
                        <GroupBox Header="Tipo de Controlador" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <StackPanel Orientation="Vertical" Margin="4">
                                <RadioButton x:Name="RbGrbl" Content="GRBL" IsChecked="True"
                                             Foreground="#cdd6f4" Margin="4,2"/>
                                <RadioButton x:Name="RbMach3" Content="Mach3"
                                             Foreground="#cdd6f4" Margin="4,2"/>
                                <RadioButton x:Name="RbIso" Content="Outro (ISO genérico / A20Z)"
                                             Foreground="#cdd6f4" Margin="4,2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Preset -->
                        <GroupBox Header="Preset Rápido" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <StackPanel Orientation="Horizontal" Margin="4">
                                <Label Content="Controlador:" Style="{StaticResource SmallLabel}" Width="90"/>
                                <ComboBox x:Name="CmbPreset" Style="{StaticResource DarkCombo}" Width="300"
                                          SelectionChanged="CmbPreset_Changed"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- M Codes -->
                        <GroupBox Header="M Codes — Laser / Spindle" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                    <RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>

                                <Label Grid.Row="0" Content="M ON (ligar):"   Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbMOn"   Style="{StaticResource DarkTextBox}" Margin="2" TextChanged="Preview_Changed"/>

                                <Label Grid.Row="1" Content="M OFF (desligar):" Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbMOff"  Style="{StaticResource DarkTextBox}" Margin="2" TextChanged="Preview_Changed"/>

                                <Label Grid.Row="2" Content="Home:"            Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TbHome"  Style="{StaticResource DarkTextBox}" Margin="2"/>

                                <Label Grid.Row="3" Content="Unlock:"          Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TbUnlock" Style="{StaticResource DarkTextBox}" Margin="2"/>

                                <Label Grid.Row="4" Content="Pierce delay (s):" Style="{StaticResource SmallLabel}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" x:Name="TbPierce" Style="{StaticResource DarkTextBox}" Margin="2" TextChanged="Preview_Changed"/>
                            </Grid>
                        </GroupBox>

                        <!-- Preview -->
                        <Label Content="Preview G-code gerado:" Style="{StaticResource SmallLabel}"/>
                        <TextBlock x:Name="TbPreview"
                                   Background="#11111b" Foreground="#a6e3a1"
                                   FontFamily="Consolas,Courier New" FontSize="12"
                                   Padding="8" TextWrapping="Wrap" Margin="0,2"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Tab 2: Laser / Plasma (S, PWM) ─────────────────────── -->
            <TabItem Header="Laser / Plasma">
                <StackPanel Margin="8">
                    <GroupBox Header="Parâmetros S (laser ou plasma)" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="S máximo laser:" Style="{StaticResource SmallLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbMaxS" Style="{StaticResource DarkTextBox}" Margin="2" TextChanged="Preview_Changed"/>

                            <Label Grid.Row="1" Content="S máximo plasma:" Style="{StaticResource SmallLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbPlasmaMaxS" Style="{StaticResource DarkTextBox}" Margin="2"/>

                            <Label Grid.Row="2" Content="Modo laser:" Style="{StaticResource SmallLabel}"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="2">
                                <RadioButton x:Name="RbPwm" Content="PWM (0-100%)" IsChecked="True"
                                             Foreground="#cdd6f4" Margin="2,0"/>
                                <RadioButton x:Name="RbTtl" Content="TTL (On/Off)"
                                             Foreground="#cdd6f4" Margin="8,0"/>
                            </StackPanel>

                            <Label Grid.Row="3" Content="Controlo plasma:" Style="{StaticResource SmallLabel}"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Vertical" Margin="2">
                                <RadioButton x:Name="RbPlasmaPwm" Content="S define intensidade (PWM)"
                                             GroupName="PlasmaTorchCfg" Foreground="#cdd6f4" Margin="2,2"/>
                                <RadioButton x:Name="RbPlasmaOnOff" Content="Só M ligar / desligar (sem S)"
                                             GroupName="PlasmaTorchCfg" Foreground="#cdd6f4" Margin="2,2"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- ── Tab 3: Ligação ─────────────────────────────────────── -->
            <TabItem Header="Ligação">
                <StackPanel Margin="8">
                    <GroupBox Header="Ligação Série / USB" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="Porta COM:" Style="{StaticResource SmallLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbPort" Style="{StaticResource DarkTextBox}" Margin="2"/>

                            <Label Grid.Row="1" Content="Baud rate:" Style="{StaticResource SmallLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbBaud" Style="{StaticResource DarkTextBox}" Margin="2"/>

                            <Label Grid.Row="2" Content="Preset baud:" Style="{StaticResource SmallLabel}"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="CmbBaud"
                                      Style="{StaticResource DarkCombo}" Margin="2"
                                      SelectionChanged="CmbBaud_Changed">
                                <ComboBoxItem Content="9600"/>
                                <ComboBoxItem Content="19200"/>
                                <ComboBoxItem Content="57600"/>
                                <ComboBoxItem Content="115200" IsSelected="True"/>
                                <ComboBoxItem Content="230400"/>
                                <ComboBoxItem Content="250000"/>
                                <ComboBoxItem Content="500000"/>
                            </ComboBox>
                        </Grid>
                    </GroupBox>
                    <TextBlock Text="Nota: A20Z Flymotion usa tipicamente 115200 baud.&#10;GRBL standard: 115200. Verificar configuração da placa."
                               Foreground="#6c7086" FontSize="11" Margin="4,4" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <!-- ── Tab: Visualização ─────────────────────────────────── -->
            <TabItem Header="Visualização">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Foreground="#6c7086" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="Opções do painel 3D (viewport): marca de água e aparência."/>

                        <GroupBox Header="Marca de água" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <StackPanel Margin="4">
                                <TextBlock Foreground="#6c7086" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                           Text="Opacidade do logo centrado por cima do percurso 3D. 0% = invisível."/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SldWatermarkOpacity" Grid.Column="0"
                                            Minimum="0" Maximum="100" TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" MinWidth="40"
                                               Foreground="#cdd6f4" FontSize="12"
                                               Text="{Binding Value, ElementName=SldWatermarkOpacity, StringFormat={}{0:F0}%}"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Simulação do percurso" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <StackPanel Margin="4">
                                <TextBlock Foreground="#6c7086" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                           Text="Velocidade em relação ao feed F do programa e ao avanço em G0. 100% = tempo proporcional ao avanço."/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="SldSimulationSpeed" Grid.Column="0"
                                            Minimum="10" Maximum="400" TickFrequency="5"
                                            IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" MinWidth="48"
                                               Foreground="#cdd6f4" FontSize="12"
                                               Text="{Binding Value, ElementName=SldSimulationSpeed, StringFormat={}{0:F0}%}"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Fundo do viewport 3D" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                            <StackPanel Margin="4">
                                <TextBlock Foreground="#6c7086" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                           Text="Define a cor de fundo do viewport (HEX). Ex.: #11111b ou #FF11111B"/>
                                <ComboBox x:Name="CmbViewportBackgroundPreset"
                                          Margin="0,0,0,6"
                                          Style="{StaticResource DarkCombo}"
                                          SelectionChanged="CmbViewportBackgroundPreset_Changed">
                                        <ComboBoxItem Content="Selecionar predefinição..." Tag="" IsSelected="True"/>
                                        <ComboBoxItem Content="Escuro (padrão)" Tag="#11111b"/>
                                        <ComboBoxItem Content="Claro (suave)" Tag="#ece8e1"/>
                                        <ComboBoxItem Content="Azul técnico" Tag="#1d2a36"/>
                                        <ComboBoxItem Content="Cinza neutro" Tag="#2b2b2f"/>
                                </ComboBox>
                                <TextBox x:Name="TbViewportBackground"
                                         Style="{StaticResource DarkTextBox}"
                                         Margin="0,0,0,0"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Tab: Tubo / Máquina ───────────────────────────────── -->
            <TabItem Header="Tubo / Máquina">
                <StackPanel Margin="8">
                    <GroupBox Header="Dimensões do Tubo" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="Largura W (mm):" Style="{StaticResource SmallLabel}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TbW" Style="{StaticResource DarkTextBox}" Margin="2"/>

                            <Label Grid.Row="1" Content="Altura H (mm):" Style="{StaticResource SmallLabel}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TbH" Style="{StaticResource DarkTextBox}" Margin="2"/>

                            <Label Grid.Row="2" Content="Standoff (mm):" Style="{StaticResource SmallLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TbStandoff" Style="{StaticResource DarkTextBox}" Margin="2"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Velocidade Jog" Style="{StaticResource DarkGroupBox}" Margin="0,4">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Feed jog (mm/min):" Style="{StaticResource SmallLabel}"/>
                            <TextBox Grid.Column="1" x:Name="TbJogFeed" Style="{StaticResource DarkTextBox}" Margin="2"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
