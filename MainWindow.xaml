<Window x:Class="AxiomFusion.CncController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AxiomFusion.CncController.Views"
        Title="AxiomFusion CNC — Multi-Machine Controller"
        Height="900" Width="1400"
        WindowState="Maximized"
        Background="#1e1e2e">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Assets/Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>
        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <ToolBar DockPanel.Dock="Top" Style="{StaticResource DarkToolBar}">

            <!-- Tipo de máquina -->
            <Label Content="Máquina:" Style="{StaticResource ToolbarLabel}"/>
            <ComboBox x:Name="CmbMachine" Width="140" Style="{StaticResource DarkCombo}"
                      ItemsSource="{Binding MachineTypeNames}"
                      SelectedItem="{Binding SelectedMachineName}"/>
            <Separator/>

            <!-- Porta + Ligar -->
            <Label Content="Porta:" Style="{StaticResource ToolbarLabel}"/>
            <ComboBox x:Name="CmbPort" Width="100" Style="{StaticResource DarkCombo}"
                      ItemsSource="{Binding AvailablePorts}"
                      SelectedItem="{Binding SelectedPort}"/>
            <Button Width="32" Padding="4,2" Style="{StaticResource SmallButton}"
                    ToolTip="Actualizar lista de portas COM"
                    Command="{Binding RefreshPortsCommand}">
                <Image Style="{StaticResource AxiomUiIconSolo}"/>
            </Button>
            <ToggleButton x:Name="BtnConnect"
                          Content="{Binding ConnectLabel}"
                          IsChecked="{Binding IsConnected}"
                          Style="{StaticResource ConnectToggle}"
                          Command="{Binding ToggleConnectCommand}"/>
            <TextBlock Text="{Binding ControllerTypeLabel}"
                       Foreground="#f9e2af" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="8,0"/>
            <Separator/>

            <!-- Máquina -->
            <Button Style="{StaticResource ToolbarButton}" Command="{Binding HomeCommand}"
                    ToolTip="Home ($H)">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconBeforeLabel}"/>
                    <TextBlock Text="Home" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource ToolbarButton}" Command="{Binding UnlockCommand}"
                    ToolTip="Desbloquear alarme ($X)">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconBeforeLabel}"/>
                    <TextBlock Text="Desbloquear" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Separator/>

            <!-- Ciclo -->
            <Button Style="{StaticResource StartButton}" Command="{Binding StartProgramCommand}" Margin="2"
                    ToolTip="Iniciar programa (ciclo)">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconBeforeLabel}"/>
                    <TextBlock Text="Iniciar" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource HoldButton}" Command="{Binding FeedHoldCommand}" Margin="2"
                    ToolTip="Feed hold — pausa o avanço">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconBeforeLabel}"/>
                    <TextBlock Text="Parar" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource AbortButton}" Command="{Binding AbortProgramCommand}" Margin="2"
                    ToolTip="Abortar / reset do programa">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconBeforeLabel}"/>
                    <TextBlock Text="Abortar" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Button>
            <Separator/>

            <!-- Configuração -->
            <Button Style="{StaticResource ToolbarButton}" Click="BtnSettings_Click"
                    ToolTip="Configuração da máquina e ligação">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconBeforeLabel}"/>
                    <TextBlock Text="Configuração" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- ── Status Bar ──────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Style="{StaticResource DarkStatusBar}">
            <StatusBarItem>
                <TextBlock x:Name="TbConnStatus" Text="Desligado" Foreground="#6c7086"/>
            </StatusBarItem>
            <Separator Style="{StaticResource DarkSeparator}"/>
            <StatusBarItem>
                <TextBlock x:Name="TbPort" Text="" Foreground="#6c7086"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding MachineName, StringFormat='  [{0}]'}"
                           Foreground="#89b4fa" FontWeight="Bold"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding CurrentLine, StringFormat='Linha {0}'}"
                               Foreground="#6c7086"/>
                    <TextBlock Text="{Binding TotalLines, StringFormat=' / {0}'}"
                               Foreground="#6c7086"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Layout principal ────────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200" MaxWidth="320"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="260" MinWidth="220" MaxWidth="340"/>
            </Grid.ColumnDefinitions>

            <!-- Coluna ESQUERDA -->
            <DockPanel Grid.Column="0" Margin="4">
                <views:DroPanel    DockPanel.Dock="Top" DataContext="{Binding}" Margin="0,0,0,4"/>
                <views:JogPanel    DockPanel.Dock="Top" DataContext="{Binding}" Margin="0,0,0,4"/>
                <views:OffsetPanel                       DataContext="{Binding}"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#313244"/>

            <!-- Centro: Visualizador + GCode + MDI -->
            <Grid Grid.Column="2" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <views:VisualizerPanel x:Name="VizPanel"   Grid.Row="0" DataContext="{Binding}"/>
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#313244"/>
                <views:GCodePanel     x:Name="GcodePanel"  Grid.Row="2" DataContext="{Binding}"/>
                <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="#313244"/>
                <views:MdiPanel                             Grid.Row="4" DataContext="{Binding}"/>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#313244"/>

            <!-- Coluna DIREITA — painel dinâmico por tipo de máquina -->
            <DockPanel Grid.Column="4" Margin="4">
                <views:StatusPanel DockPanel.Dock="Top" DataContext="{Binding}" Margin="0,0,0,4"/>

                <!-- Laser -->
                <views:LaserPanel     DataContext="{Binding}"
                                      Visibility="{Binding LaserPanelVisible}"/>
                <!-- Plasma -->
                <views:PlasmaPanel    DataContext="{Binding}"
                                      Visibility="{Binding PlasmaPanelVisible}"/>
                <!-- Fresa / Furadeira -->
                <views:DrillPanel     DataContext="{Binding}"
                                      Visibility="{Binding DrillPanelVisible}"/>
                <!-- Torno -->
                <views:TurnPanel      DataContext="{Binding}"
                                      Visibility="{Binding TurnPanelVisible}"/>
                <!-- Torno + Laser -->
                <views:TurnLaserPanel DataContext="{Binding}"
                                      Visibility="{Binding TurnLaserPanelVisible}"/>
                <!-- Torno + Plasma -->
                <views:TurnPlasmaPanel DataContext="{Binding}"
                                       Visibility="{Binding TurnPlasmaPanelVisible}"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
