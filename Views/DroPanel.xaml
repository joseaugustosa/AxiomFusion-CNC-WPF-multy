<UserControl x:Class="AxiomFusion.CncController.Views.DroPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Posição" Style="{StaticResource DarkGroupBox}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Toggle Work/Machine -->
            <ToggleButton Grid.Row="0" x:Name="BtnToggle"
                          Content="Trabalho" Margin="2,4"
                          IsChecked="{Binding ShowWork}"
                          Style="{StaticResource DarkToggleButton}"
                          Checked="BtnToggle_Changed"
                          Unchecked="BtnToggle_Changed"/>

            <!-- X -->
            <Grid Grid.Row="1" Margin="2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="X" Style="{StaticResource AxisLabel}"/>
                <TextBlock x:Name="TbX" Grid.Column="1" Style="{StaticResource DroDisplay}"
                           Text="{Binding PosX, StringFormat={}{0:F3}}"/>
            </Grid>

            <!-- Y -->
            <Grid Grid.Row="2" Margin="2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Y" Style="{StaticResource AxisLabel}"/>
                <TextBlock x:Name="TbY" Grid.Column="1" Style="{StaticResource DroDisplay}"
                           Text="{Binding PosY, StringFormat={}{0:F3}}"/>
            </Grid>

            <!-- Z -->
            <Grid Grid.Row="3" Margin="2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="Z" Style="{StaticResource AxisLabel}"/>
                <TextBlock x:Name="TbZ" Grid.Column="1" Style="{StaticResource DroDisplay}"
                           Text="{Binding PosZ, StringFormat={}{0:F3}}"/>
            </Grid>

            <!-- A -->
            <Grid Grid.Row="4" Margin="2,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Content="A" Style="{StaticResource AxisLabel}"/>
                <TextBlock x:Name="TbA" Grid.Column="1" Style="{StaticResource DroDisplay}"
                           Text="{Binding PosA, StringFormat={}{0:F2}°}"/>
            </Grid>

            <!-- mm label -->
            <TextBlock Grid.Row="5" Text="mm / graus" Foreground="#6c7086"
                       FontSize="10" HorizontalAlignment="Right" Margin="4,2"/>
        </Grid>
    </GroupBox>
</UserControl>
