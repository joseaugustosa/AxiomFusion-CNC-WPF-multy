<UserControl x:Class="AxiomFusion.CncController.Views.StatusPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Estado da Máquina" Style="{StaticResource DarkGroupBox}">
        <StackPanel>
            <!-- Estado principal -->
            <Border x:Name="StateBorder" BorderThickness="2" CornerRadius="4"
                    BorderBrush="{Binding StatusColor, Converter={StaticResource StringToBrush}}"
                    Margin="4,4,4,8" Padding="6">
                <TextBlock Text="{Binding StatusLabel}" FontSize="22" FontWeight="Bold"
                           Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Feed / Laser -->
            <Grid Margin="4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Label Content="Feed:" Style="{StaticResource SmallLabel}"/>
                    <TextBlock Style="{StaticResource ValueDisplay}"
                               Text="{Binding FeedRate, StringFormat={}{0} mm/min}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <Label Content="{Binding SpindleOrLaserLabel}" Style="{StaticResource SmallLabel}"/>
                    <TextBlock Style="{StaticResource ValueDisplay}"
                               Text="{Binding LaserPower}"/>
                </StackPanel>
            </Grid>

            <Separator Style="{StaticResource DarkSeparator}" Margin="4"/>

            <!-- Override de feed -->
            <Label Content="Override Feed:" Style="{StaticResource SmallLabel}" Margin="4,0"/>
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <Button Content="-10%" Width="44" Style="{StaticResource SmallButton}"
                        Command="{Binding SetFeedOverrideCommand}" CommandParameter="-1"/>
                <TextBlock Text="{Binding FeedOverride, StringFormat={}{0}%}"
                           Foreground="#89b4fa" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" Width="50" TextAlignment="Center"/>
                <Button Content="+10%" Width="44" Style="{StaticResource SmallButton}"
                        Command="{Binding SetFeedOverrideCommand}" CommandParameter="1"/>
                <Button Content="100%" Width="44" Style="{StaticResource SmallButton}"
                        Command="{Binding SetFeedOverrideCommand}" CommandParameter="0"
                        Margin="4,0,0,0"/>
            </StackPanel>

            <Separator Style="{StaticResource DarkSeparator}" Margin="4"/>

            <!-- Fins de curso -->
            <Label Content="Fins de Curso:" Style="{StaticResource SmallLabel}" Margin="4,0"/>
            <StackPanel Orientation="Horizontal" Margin="4,2" HorizontalAlignment="Center">
                <Border Style="{StaticResource LimitIndicator}" Margin="4,0">
                    <TextBlock Text="X" Style="{StaticResource LimitLabel}"/>
                </Border>
                <Border Style="{StaticResource LimitIndicator}" Margin="4,0">
                    <TextBlock Text="Y" Style="{StaticResource LimitLabel}"/>
                </Border>
                <Border Style="{StaticResource LimitIndicator}" Margin="4,0">
                    <TextBlock Text="Z" Style="{StaticResource LimitLabel}"/>
                </Border>
            </StackPanel>

            <!-- Mensagem de estado -->
            <Separator Style="{StaticResource DarkSeparator}" Margin="4"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#cdd6f4"
                       FontSize="11" TextWrapping="Wrap" Margin="4,2"
                       MaxHeight="60"/>
        </StackPanel>
    </GroupBox>
</UserControl>
