<UserControl x:Class="AxiomFusion.CncController.Views.TurnLaserPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Torno + Laser" Style="{StaticResource DarkGroupBox}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ══ TORNO ══════════════════════════════════════════════════ -->
            <Border BorderBrush="#45475a" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                <Label Content="— Torno —" Style="{StaticResource SmallLabel}"
                       Foreground="#89b4fa" FontWeight="Bold" Margin="4,2"/>
            </Border>

            <!-- Spindle RPM -->
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <TextBox x:Name="TbRpm" Width="70" Style="{StaticResource DarkTextBox}"
                         Text="{Binding SpindleRpm, StringFormat={}{0:F0}}"
                         LostFocus="TbRpm_LostFocus"/>
                <Label Content="RPM" Style="{StaticResource SmallLabel}"/>
                <Button Style="{StaticResource SmallButton}" Margin="2,0"
                        Command="{Binding ApplySpindleRpmCommand}" ToolTip="Enviar RPM (comando S)">
                    <StackPanel Orientation="Horizontal">
                        <Image Style="{StaticResource AxiomUiIconJog}" VerticalAlignment="Center"/>
                        <TextBlock Text="S" FontWeight="Bold" VerticalAlignment="Center" Margin="3,0,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <UniformGrid Rows="1" Columns="3" Margin="4,2">
                <Button Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding SpindleOnCommand}" ToolTip="M3 — sentido normal">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Style="{StaticResource AxiomUiIconCompact}"/>
                        <TextBlock Text="M3" VerticalAlignment="Center" Margin="4,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding SpindleReverseCommand}" ToolTip="M4 — inversão">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Style="{StaticResource AxiomUiIconCompact}"/>
                        <TextBlock Text="M4" VerticalAlignment="Center" Margin="4,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AbortButton}" Margin="2"
                        Command="{Binding SpindleOffCommand}" ToolTip="M5 — parar spindle">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Style="{StaticResource AxiomUiIconCompact}"/>
                        <TextBlock Text="M5" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <CheckBox Content="Modo Diâmetro G7" Foreground="#cdd6f4" Margin="4,4"
                      IsChecked="{Binding DiameterMode}" Click="DiameterMode_Click"/>

            <UniformGrid Rows="1" Columns="2" Margin="4,2">
                <Button Content="M8  Refrigeração" Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding CoolantOnCmdCommand}"/>
                <Button Content="M9  OFF" Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding CoolantOffCmdCommand}"/>
            </UniformGrid>

            <Separator Style="{StaticResource DarkSeparator}" Margin="4,8"/>

            <!-- ══ LASER ══════════════════════════════════════════════════ -->
            <Border BorderBrush="#45475a" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                <Label Content="— Laser —" Style="{StaticResource SmallLabel}"
                       Foreground="#a6e3a1" FontWeight="Bold" Margin="4,2"/>
            </Border>

            <!-- Potência PWM -->
            <Label Content="Potência:" Style="{StaticResource SmallLabel}" Margin="4,0"/>
            <Slider x:Name="SliderPwm" Minimum="0" Maximum="100"
                    Value="{Binding LaserPwmPct}"
                    Style="{StaticResource DarkSlider}" Margin="4,2"
                    ValueChanged="SliderPwm_Changed"/>
            <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
                <TextBlock Text="{Binding LaserPwmPct, StringFormat={}{0:F0}%}"
                           Foreground="#a6e3a1" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="TbSValue" Text=" S=1000" Foreground="#6c7086"
                           FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Laser on/off + teste -->
            <UniformGrid Rows="1" Columns="2" Margin="4,2">
                <Button Content="M7  Laser ON"  Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding TurnLaserOnCommand}"/>
                <Button Content="M107 Laser OFF" Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding TurnLaserOffCommand}"/>
            </UniformGrid>

            <Separator Style="{StaticResource DarkSeparator}" Margin="4,4"/>

            <!-- Disparo de teste -->
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <Label Content="Teste:" Style="{StaticResource SmallLabel}" Width="48"/>
                <TextBox x:Name="TbDuration" Text="500" Width="55"
                         Style="{StaticResource DarkTextBox}"/>
                <Label Content="ms" Style="{StaticResource SmallLabel}"/>
                <Button Content="Disparar" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                        Click="BtnTestFire_Click"/>
            </StackPanel>

        </StackPanel>
        </ScrollViewer>
    </GroupBox>
</UserControl>
