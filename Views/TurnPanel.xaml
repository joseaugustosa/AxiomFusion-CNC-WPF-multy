<UserControl x:Class="AxiomFusion.CncController.Views.TurnPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <GroupBox Header="Controlo Torno" Style="{StaticResource DarkGroupBox}">
        <StackPanel>

            <!-- ── Modo velocidade ─────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Margin="4,4,4,2">
                <RadioButton x:Name="RbRpm" Content="RPM fixo"   Foreground="#cdd6f4"
                             IsChecked="True" Margin="0,0,12,0" VerticalAlignment="Center"
                             Checked="SpeedMode_Changed"/>
                <RadioButton x:Name="RbCss" Content="CSS (m/min)" Foreground="#cdd6f4"
                             IsChecked="{Binding CssMode}" VerticalAlignment="Center"
                             Checked="SpeedMode_Changed"/>
            </StackPanel>

            <!-- Valor de velocidade -->
            <StackPanel Orientation="Horizontal" Margin="4,2">
                <TextBox x:Name="TbSpeed" Width="80" Style="{StaticResource DarkTextBox}"
                         Text="{Binding SpindleRpm, StringFormat={}{0:F0}}"
                         LostFocus="TbSpeed_LostFocus"/>
                <Label x:Name="LbSpeedUnit" Content="RPM" Style="{StaticResource SmallLabel}"/>
                <Button Content="Aplicar" Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                        Command="{Binding ApplyCssSpeedCommand}"/>
            </StackPanel>

            <!-- ── Controlo spindle ───────────────────────────────────── -->
            <Label Content="Spindle:" Style="{StaticResource SmallLabel}" Margin="4,6,4,0"/>
            <UniformGrid Rows="1" Columns="3" Margin="4,2">
                <Button Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding SpindleOnCommand}" ToolTip="M3 — sentido normal">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Style="{StaticResource AxiomUiIconCompact}"/>
                        <TextBlock Text="M3" VerticalAlignment="Center" Margin="4,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding SpindleReverseCommand}" ToolTip="M4 — inversão">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Style="{StaticResource AxiomUiIconCompact}"/>
                        <TextBlock Text="M4" VerticalAlignment="Center" Margin="4,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource AbortButton}" Margin="2"
                        Command="{Binding SpindleOffCommand}" ToolTip="M5 — parar spindle">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Image Style="{StaticResource AxiomUiIconCompact}"/>
                        <TextBlock Text="M5" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Margin="4,0,0,0"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Separator Style="{StaticResource DarkSeparator}" Margin="4,6"/>

            <!-- ── Modo coordenadas X ─────────────────────────────────── -->
            <CheckBox Content="Modo Diâmetro — G7 (X = ⌀)"
                      Foreground="#cdd6f4" Margin="4,4"
                      IsChecked="{Binding DiameterMode}"
                      Click="DiameterMode_Click"/>

            <Separator Style="{StaticResource DarkSeparator}" Margin="4,6"/>

            <!-- ── Refrigeração ────────────────────────────────────────── -->
            <Label Content="Refrigeração:" Style="{StaticResource SmallLabel}" Margin="4,0"/>
            <UniformGrid Rows="1" Columns="2" Margin="4,2">
                <Button Content="M8  Ligar"    Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding CoolantOnCmdCommand}"/>
                <Button Content="M9  Desligar" Style="{StaticResource SmallButton}" Margin="2"
                        Command="{Binding CoolantOffCmdCommand}"/>
            </UniformGrid>

        </StackPanel>
    </GroupBox>
</UserControl>
