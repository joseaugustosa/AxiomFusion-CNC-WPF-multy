<UserControl x:Class="AxiomFusion.CncController.Views.VisualizerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="http://helix-toolkit.org/wpf">
    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Style="{StaticResource DarkToolBar}">
            <Button Style="{StaticResource SmallButton}" Click="BtnFit_Click"
                    ToolTip="Encaixar vista ao modelo (zoom extents)">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconCompact}" Margin="0,0,6,0"/>
                    <TextBlock Text="Ajustar vista" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Separator/>
            <ToggleButton x:Name="BtnTube" IsChecked="True"
                          Style="{StaticResource DarkToggleButton}" Click="BtnTube_Click"
                          ToolTip="Mostrar ou ocultar o tubo no 3D">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconCompact}" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TbTubeLabel" Text="Tubo: ON" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            <ToggleButton x:Name="BtnLogo" IsChecked="True"
                          Style="{StaticResource DarkToggleButton}" Click="BtnLogo_Click"
                          ToolTip="Mostrar ou ocultar o logo 3D (clique no logo para velocidade)">
                <StackPanel Orientation="Horizontal">
                    <Image Style="{StaticResource AxiomUiIconCompact}" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TbLogoLabel" Text="Logo 3D: ON" VerticalAlignment="Center"/>
                </StackPanel>
            </ToggleButton>
            <Separator/>
            <TextBlock Foreground="#6c7086" FontSize="11" VerticalAlignment="Center" Margin="6,0"
                       Text="Vista: arrastar = orbitar · Ctrl+arrastar = pan · roda do rato = zoom"/>
        </ToolBar>

        <!-- Vista única: toolpath a toda a largura; logo 3D em sobreposição (metade da antiga coluna) -->
        <Grid>
            <!-- Principal: tubo + percursos (orbit sobre toda a área) -->
            <h:HelixViewport3D x:Name="Viewport"
                               Background="#11111b"
                               ShowCoordinateSystem="True"
                               CoordinateSystemHorizontalPosition="Right"
                               CoordinateSystemVerticalPosition="Top"
                               ShowFrameRate="False"
                               IsHeadLightEnabled="True"
                               CameraRotationMode="Trackball">

                <h:HelixViewport3D.DefaultCamera>
                    <PerspectiveCamera FieldOfView="45"
                                       Position="200,200,200"
                                       LookDirection="-1,-1,-1"
                                       UpDirection="0,0,1"/>
                </h:HelixViewport3D.DefaultCamera>

                <h:GridLinesVisual3D x:Name="Grid"
                                     Width="200" Length="200"
                                     MajorDistance="50" MinorDistance="10"
                                     Thickness="0.3">
                    <h:GridLinesVisual3D.Material>
                        <DiffuseMaterial>
                            <DiffuseMaterial.Brush>
                                <SolidColorBrush Color="#444466" Opacity="0.15"/>
                            </DiffuseMaterial.Brush>
                        </DiffuseMaterial>
                    </h:GridLinesVisual3D.Material>
                </h:GridLinesVisual3D>

                <h:MeshGeometryVisual3D x:Name="TubeVisual">
                    <h:MeshGeometryVisual3D.Material>
                        <DiffuseMaterial>
                            <DiffuseMaterial.Brush>
                                <SolidColorBrush Color="#6688aa" Opacity="0.4"/>
                            </DiffuseMaterial.Brush>
                        </DiffuseMaterial>
                    </h:MeshGeometryVisual3D.Material>
                    <h:MeshGeometryVisual3D.BackMaterial>
                        <DiffuseMaterial>
                            <DiffuseMaterial.Brush>
                                <SolidColorBrush Color="#446688" Opacity="0.15"/>
                            </DiffuseMaterial.Brush>
                        </DiffuseMaterial>
                    </h:MeshGeometryVisual3D.BackMaterial>
                </h:MeshGeometryVisual3D>

                <!-- Cores em forte contraste com o fundo #11111b -->
                <h:LinesVisual3D x:Name="PathRapid"
                                 Color="#b4befe" Thickness="1.25"/>
                <h:LinesVisual3D x:Name="PathTravel"
                                 Color="#f9e2af" Thickness="1.75"/>
                <h:LinesVisual3D x:Name="PathCut"
                                 Color="#ff6b6b" Thickness="2.5"/>

                <h:LinesVisual3D x:Name="PathCurrent"
                                 Color="#ffffff" Thickness="3.5"/>

                <!-- Bico do laser durante simulação: esfera (corpo) + seta (feixe até ao ponto de corte) -->
                <h:SphereVisual3D x:Name="LaserNozzleSphere" Radius="3.2" Visible="False">
                    <h:SphereVisual3D.Fill>
                        <SolidColorBrush Color="#ff7a4a"/>
                    </h:SphereVisual3D.Fill>
                </h:SphereVisual3D>
                <h:ArrowVisual3D x:Name="LaserNozzleBeam" Visible="False"
                                 Diameter="2.2" HeadLength="6">
                    <h:ArrowVisual3D.Fill>
                        <SolidColorBrush Color="#ffaa77"/>
                    </h:ArrowVisual3D.Fill>
                </h:ArrowVisual3D>
            </h:HelixViewport3D>

            <!-- Marca de água (logo) — não interfere com orbit / pan / zoom -->
            <Viewbox x:Name="WatermarkViewbox"
                     Stretch="Uniform"
                     MaxWidth="480" MaxHeight="480"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Opacity="0.09"
                     IsHitTestVisible="False"
                     Panel.ZIndex="0">
                <Image Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Source="pack://application:,,,/AxiomFusion.CncController;component/Assets/Icons/axiom-logo.png"/>
            </Viewbox>

            <!-- Logo: canto superior esquerdo; camada transparente captura clique para ajustar rotação -->
            <Border x:Name="LogoOverlay"
                    Width="174" Height="174"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="6" Background="Transparent"
                    IsHitTestVisible="True"
                    Panel.ZIndex="1">
                <Grid>
                    <h:HelixViewport3D x:Name="LogoViewport"
                                       Background="Transparent"
                                       ShowCoordinateSystem="False"
                                       ShowViewCube="False"
                                       ShowFrameRate="False"
                                       IsHeadLightEnabled="True"
                                       Loaded="LogoViewport_Loaded"
                                       SizeChanged="LogoViewport_SizeChanged">
                        <h:HelixViewport3D.DefaultCamera>
                            <PerspectiveCamera FieldOfView="44"
                                               Position="0, -95, 38"
                                               LookDirection="0, 1, -0.15"
                                               UpDirection="0, 0, 1"/>
                        </h:HelixViewport3D.DefaultCamera>
                        <ModelVisual3D x:Name="LogoModelVisual"/>
                    </h:HelixViewport3D>
                    <Border Background="Transparent" Cursor="Hand"
                            ToolTip="Clique para ajustar a velocidade de rotação"
                            MouseLeftButtonUp="LogoHitArea_MouseLeftButtonUp"/>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
